import streamlit as st
import pandas as pd
import pickle

# Load dataset (for encoders)
df = pd.read_csv("matches.csv")
df = df[['team1', 'team2', 'toss_winner', 'venue', 'winner']]
df = df.dropna()

# Fix team names (important)
df = df.replace("Royal Challengers Bengaluru", "Royal Challengers Bangalore")
df = df.replace("Delhi Daredevils", "Delhi Capitals")

# Encode
from sklearn.preprocessing import LabelEncoder

team_encoder = LabelEncoder()
all_teams = pd.concat([df['team1'], df['team2'], df['toss_winner'], df['winner']])
team_encoder.fit(all_teams)

venue_encoder = LabelEncoder()
venue_encoder.fit(df['venue'])

# Load trained model
model = pickle.load(open("model.pkl", "rb"))

# ---------------- UI ---------------- #

st.title("🏏 IPL Match Winner Predictor")

team_list = list(team_encoder.classes_)
venue_list = list(venue_encoder.classes_)

team1 = st.selectbox("Select Team 1", team_list)
team2 = st.selectbox("Select Team 2", team_list)
toss = st.selectbox("Toss Winner", team_list)
venue = st.selectbox("Venue", venue_list)

if st.button("Predict Winning Probability"):

    input_data = [[
        team_encoder.transform([team1])[0],
        team_encoder.transform([team2])[0],
        team_encoder.transform([toss])[0],
        venue_encoder.transform([venue])[0]
    ]]

    probs = model.predict_proba(input_data)
    classes = model.classes_

    st.subheader("Winning Probability:")

    for i, prob in enumerate(probs[0]):
        team_name = team_encoder.inverse_transform([classes[i]])[0]

        if team_name == team1 or team_name == team2:
            st.write(f"{team_name} → {round(prob*100, 2)}%")



